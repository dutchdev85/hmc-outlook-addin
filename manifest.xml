<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.2</Version>
  <ProviderName>Halse-Martin Construction</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="HMC Pricing Intake"/>
  <Description DefaultValue="File email attachments to SharePoint SubPricing list."/>

  <IconUrl DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/icon-64.png"/>
  <SupportUrl DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/taskpane.html"/>

  <AppDomains>
    <AppDomain>https://dutchdev85.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>true</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="btnOpenTaskpane">
                  <Label resid="btnLabel"/>
                  <Supertip>
                    <Title resid="btnLabel"/>
                    <Description resid="btnDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="residTaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="residTaskpaneUrl" DefaultValue="https://dutchdev85.github.io/hmc-outlook-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="HMC Pricing"/>
        <bt:String id="btnLabel" DefaultValue="File Pricing"/>
        <bt:String id="btnDesc" DefaultValue="Open the pricing intake panel to file this email attachment"/>
      </bt:ShortStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
